<section class="row justify-content-center">
  <div class="col-12 col-md-10 col-lg-7">
    <article class="card shadow-sm">
      <div class="card-header">
        <h1 class="h4 mb-0">Crear cuenta</h1>
      </div>
      <div class="card-body">
        <form id="registerForm" class="row g-3">
          <div class="col-md-6">
            <label for="first_name" class="form-label">Nombre</label>
            <input id="first_name" name="first_name" type="text" class="form-control" required />
          </div>
          <div class="col-md-6">
            <label for="last_name" class="form-label">Apellido</label>
            <input id="last_name" name="last_name" type="text" class="form-control" required />
          </div>
          <div class="col-md-8">
            <label for="email" class="form-label">Email</label>
            <input id="email" name="email" type="email" class="form-control" required />
          </div>
          <div class="col-md-4">
            <label for="age" class="form-label">Edad</label>
            <input id="age" name="age" type="number" min="1" class="form-control" required />
          </div>
          <div class="col-md-8">
            <label for="password" class="form-label">Contraseña</label>
            <input id="password" name="password" type="password" class="form-control" required />
          </div>
          <div class="col-md-4">
            <label for="role" class="form-label">Rol</label>
            <select id="role" name="role" class="form-select">
              <option value="user" selected>user</option>
              <option value="admin">admin</option>
            </select>
          </div>
          <div class="col-12 d-grid">
            <button type="submit" class="btn btn-primary">Registrarme</button>
          </div>
        </form>

        <div id="registerError" class="alert alert-danger mt-3 d-none" role="alert"></div>
        <div id="registerSuccess" class="alert alert-success mt-3 d-none" role="alert">
          Usuario registrado correctamente. Redirigiendo...
        </div>

        <p class="text-muted mt-3 mb-0">
          ¿Ya tienes cuenta?
          <a href="/login">Inicia sesión</a>
        </p>
      </div>
    </article>
  </div>
</section>

<script>
  const registerForm = document.getElementById("registerForm");
  const registerError = document.getElementById("registerError");
  const registerSuccess = document.getElementById("registerSuccess");

  function showRegisterError(message) {
    registerError.textContent = message;
    registerError.classList.remove("d-none");
    registerSuccess.classList.add("d-none");
  }

  function showRegisterSuccess() {
    registerSuccess.classList.remove("d-none");
    registerError.classList.add("d-none");
  }

  registerForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    registerError.classList.add("d-none");

    const payload = {
      first_name: registerForm.first_name.value.trim(),
      last_name: registerForm.last_name.value.trim(),
      email: registerForm.email.value.trim(),
      age: Number(registerForm.age.value),
      password: registerForm.password.value,
      role: registerForm.role.value,
    };

    try {
      const res = await fetch("/api/sessions/register", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok) {
        return showRegisterError(data.error || "No se pudo registrar el usuario");
      }

      if (data.user && data.user.cart && data.user.cart.id) {
        localStorage.setItem("cartId", String(data.user.cart.id));
      }
      showRegisterSuccess();
      setTimeout(() => {
        window.location.href = "/products";
      }, 1000);
    } catch (err) {
      showRegisterError("Error de conexión al registrar");
    }
  });
</script>
