<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}} - API Productos</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <style>
      /* Colores de botones: cambia los valores aquí para personalizar */
      .btn-primary {
        background-color: #b392ac;
        border-color: #b382a8;
      }
      .btn-primary:hover {
        background-color: #735d78;
        border-color: #705077;
      }
      .btn-danger {
        background-color: #e8c2ca;
        border-color: #e2b5bf;
        color: #735d78;
      }
      .btn-danger:hover {
        background-color: #d1b3c4;
        border-color: #d1a5be;
        color: #735d78;
      }
    </style>
  </head>
  <body class="bg-light">
    <div class="container py-4">
      {{{body}}}
    </div>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
    ></script>
  </body>
</html>